# Frontend environment examples

# Local dev proxy to local backend:
NEXT_PUBLIC_DEV_API_URL=/api
NEXT_DEV_BACKEND_URL=http://127.0.0.1:3000

# Production API base:
# NEXT_PUBLIC_API_URL=https://your-domain-or-ip/api
NEXT_PUBLIC_API_URL=http://127.0.0.1:3000/api
NEXT_PUBLIC_API_TIMEOUT_MS=15000

# Optional:
# If running frontend local against remote backend:
# NEXT_PUBLIC_API_URL=https://your-remote-backend-domain/api
# NEXT_DEV_BACKEND_URL=https://your-remote-backend-domain
