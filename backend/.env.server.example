# DO Server Environment Configuration
# This server acts as a proxy only

# ===================================
# Server Configuration
# ===================================
PORT=3000
NODE_ENV=production
DO_SERVER_IP=your-server-ip

# ===================================
# Authentication
# ===================================
AUTH_ENABLED=true
ADMIN_TOKEN=your_admin_token_here
JWT_SECRET=your_random_64_char_hex_string_here
CZK_PASSWORD=your_czk_user_password
LYF_PASSWORD=your_lyf_user_password

# ===================================
# Database Configuration
# Metadata default: MongoDB
# ===================================
DB_PROVIDER=mongodb
MONGODB_URI=mongodb://127.0.0.1:27017/auto_researcher
# Optional explicit DB name override:
# MONGODB_DB_NAME=auto_researcher

# Turso is still supported for document tables / compatibility:
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_token

# ===================================
# Object Storage Configuration
# Provider: aws-s3 | minio | aliyun-oss
# ===================================
OBJECT_STORAGE_PROVIDER=aws-s3
OBJECT_STORAGE_BUCKET=auto-reader-documents
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY_ID=your_object_storage_access_key
OBJECT_STORAGE_SECRET_ACCESS_KEY=your_object_storage_secret_key
# For S3 compatible providers (MinIO/OSS):
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_FORCE_PATH_STYLE=false
# Optional explicit public URL prefix used for stored object location fields:
OBJECT_STORAGE_PUBLIC_BASE_URL=

# Backward compatibility aliases
AWS_ACCESS_KEY_ID=your_object_storage_access_key
AWS_SECRET_ACCESS_KEY=your_object_storage_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=auto-reader-documents

# Example: MinIO (local or LAN)
# OBJECT_STORAGE_PROVIDER=minio
# OBJECT_STORAGE_BUCKET=auto-reader-documents
# OBJECT_STORAGE_REGION=us-east-1
# OBJECT_STORAGE_ACCESS_KEY_ID=minioadmin
# OBJECT_STORAGE_SECRET_ACCESS_KEY=minioadmin
# OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
# OBJECT_STORAGE_FORCE_PATH_STYLE=true
# OBJECT_STORAGE_PUBLIC_BASE_URL=http://127.0.0.1:9000/auto-reader-documents

# Example: Aliyun OSS
# OBJECT_STORAGE_PROVIDER=aliyun-oss
# OBJECT_STORAGE_BUCKET=your-oss-bucket
# OBJECT_STORAGE_REGION=oss-cn-hangzhou
# OBJECT_STORAGE_ACCESS_KEY_ID=your_aliyun_access_key_id
# OBJECT_STORAGE_SECRET_ACCESS_KEY=your_aliyun_access_key_secret
# OBJECT_STORAGE_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# OBJECT_STORAGE_FORCE_PATH_STYLE=false
# OBJECT_STORAGE_PUBLIC_BASE_URL=https://your-oss-bucket.oss-cn-hangzhou.aliyuncs.com

# ===================================
# CORS Configuration
# ===================================
CORS_ORIGIN=*

# ===================================
# Desktop Processing via FRP
# ===================================
PROCESSING_ENABLED=true
PROCESSING_DESKTOP_URL=http://127.0.0.1:7001
PROCESSING_TIMEOUT=300000

# Optional: Tailscale endpoint for desktop executor (used only if enabled)
TAILSCALE_ENABLED=false
TAILSCALE_DESKTOP_URL=http://100.64.0.10:7001

# Tracker heavy-op offload (DO lightweight mode)
TRACKER_ENABLED=false
TRACKER_PROXY_HEAVY_OPS=true
TRACKER_DESKTOP_URL=http://127.0.0.1:7001
TRACKER_PROXY_TIMEOUT=120000

# ===================================
# Rate Limiting
# ===================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
PAPER_ANALYSIS_WINDOW_MS=3600000
PAPER_ANALYSIS_MAX=30
CODE_ANALYSIS_WINDOW_MS=3600000
CODE_ANALYSIS_MAX=20
UPLOAD_WINDOW_MS=3600000
UPLOAD_MAX=50

# ===================================
# Reader Configuration
# Disabled on DO server - desktop handles this
# ===================================
READER_ENABLED=false

# ===================================
# Experimental X/Twitter Playwright Tracker
# ===================================
# Optional path to Playwright storage state JSON (logged-in browser session)
# X_PLAYWRIGHT_STORAGE_STATE_PATH=/var/www/auto-researcher/backend/.auth/x-state.json

# ===================================
# LLM API Keys (OPTIONAL on DO server)
# Only needed for fallback if desktop is unavailable
# ===================================
# GEMINI_API_KEY=your_gemini_api_key
# ANTHROPIC_API_KEY=your_anthropic_api_key
