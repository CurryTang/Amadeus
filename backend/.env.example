# Unified backend environment template
# Use scripts/install.sh to generate mode-specific env files automatically.

# =========================================================
# Core server
# =========================================================
PORT=3000
NODE_ENV=production
CORS_ORIGIN=*

# =========================================================
# Auth
# =========================================================
AUTH_ENABLED=true
ADMIN_TOKEN=replace_me_admin_token
JWT_SECRET=replace_me_random_secret
CZK_PASSWORD=replace_me_password
LYF_PASSWORD=replace_me_password

# =========================================================
# Metadata store: documents/tags/auth (libSQL)
# local sqlite example:
# TURSO_DATABASE_URL=file:./local.db
# TURSO_AUTH_TOKEN=
#
# Turso cloud example:
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your_turso_auth_token
# =========================================================
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# =========================================================
# Metadata store: ResearchOps (MongoDB)
# local mongodb example:
# MONGODB_URI=mongodb://127.0.0.1:27017/auto_researcher
#
# Atlas example:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/auto_researcher?retryWrites=true&w=majority
# =========================================================
DB_PROVIDER=mongodb
MONGODB_URI=mongodb://127.0.0.1:27017/auto_researcher
MONGODB_DB_NAME=auto_researcher

# =========================================================
# Paper object storage
# Provider: aws-s3 | minio | aliyun-oss
# =========================================================
OBJECT_STORAGE_PROVIDER=aws-s3
OBJECT_STORAGE_BUCKET=auto-reader-documents
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY_ID=replace_me_access_key
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace_me_secret_key
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_FORCE_PATH_STYLE=false
OBJECT_STORAGE_PUBLIC_BASE_URL=

# Backward compatibility aliases (optional but recommended)
AWS_ACCESS_KEY_ID=replace_me_access_key
AWS_SECRET_ACCESS_KEY=replace_me_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=auto-reader-documents

# MinIO example:
# OBJECT_STORAGE_PROVIDER=minio
# OBJECT_STORAGE_BUCKET=auto-reader-documents
# OBJECT_STORAGE_REGION=us-east-1
# OBJECT_STORAGE_ACCESS_KEY_ID=minioadmin
# OBJECT_STORAGE_SECRET_ACCESS_KEY=minioadmin
# OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
# OBJECT_STORAGE_FORCE_PATH_STYLE=true
# OBJECT_STORAGE_PUBLIC_BASE_URL=http://127.0.0.1:9000/auto-reader-documents

# Aliyun OSS example:
# OBJECT_STORAGE_PROVIDER=aliyun-oss
# OBJECT_STORAGE_BUCKET=your-oss-bucket
# OBJECT_STORAGE_REGION=oss-cn-hangzhou
# OBJECT_STORAGE_ACCESS_KEY_ID=your_aliyun_access_key_id
# OBJECT_STORAGE_SECRET_ACCESS_KEY=your_aliyun_access_key_secret
# OBJECT_STORAGE_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# OBJECT_STORAGE_FORCE_PATH_STYLE=false
# OBJECT_STORAGE_PUBLIC_BASE_URL=https://your-oss-bucket.oss-cn-hangzhou.aliyuncs.com

# =========================================================
# Processing / tracker topology
# =========================================================
PROCESSING_ENABLED=false
PROCESSING_DESKTOP_URL=http://127.0.0.1:7001
PROCESSING_TIMEOUT=300000

TRACKER_ENABLED=true
TRACKER_PROXY_HEAVY_OPS=false
TRACKER_DESKTOP_URL=http://127.0.0.1:7001
TRACKER_PROXY_TIMEOUT=120000

# Optional tailscale-aware routing
TAILSCALE_ENABLED=false
TAILSCALE_DESKTOP_URL=http://100.64.0.10:7001

# Reader
READER_ENABLED=true
READER_DEFAULT_PROVIDER=codex-cli
READER_CONCURRENCY=1

# =========================================================
# Optional provider API keys
# =========================================================
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
QWEN_API_KEY=
DEEPSEEK_API_KEY=

# Optional Mathpix
MATHPIX_APP_ID=
MATHPIX_APP_KEY=
