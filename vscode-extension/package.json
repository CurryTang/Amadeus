{
  "name": "auto-researcher-aris-vscode",
  "displayName": "Auto Researcher",
  "description": "Compact VS Code companion for tracked papers, library papers, and ARIS runs.",
  "version": "0.0.1",
  "publisher": "czk",
  "private": true,
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:autoResearcher.trackedPapers",
    "onView:autoResearcher.library",
    "onView:autoResearcher.arisProjects",
    "onView:autoResearcher.arisRuns",
    "onCommand:tracker.refresh",
    "onCommand:tracker.savePaper",
    "onCommand:library.refresh",
    "onCommand:library.markRead",
    "onCommand:library.markUnread",
    "onCommand:library.openPdf",
    "onCommand:library.queueReader",
    "onCommand:aris.newRun",
    "onCommand:aris.refresh",
    "onCommand:aris.retryRun",
    "onCommand:aris.copyRunId"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "autoResearcher",
          "title": "Auto Researcher",
          "icon": "media/aris.svg"
        }
      ]
    },
    "views": {
      "autoResearcher": [
        {
          "id": "autoResearcher.trackedPapers",
          "name": "Tracked Papers"
        },
        {
          "id": "autoResearcher.library",
          "name": "Library"
        },
        {
          "id": "autoResearcher.arisProjects",
          "name": "ARIS Projects"
        },
        {
          "id": "autoResearcher.arisRuns",
          "name": "ARIS Runs"
        }
      ]
    },
    "commands": [
      {
        "command": "tracker.refresh",
        "title": "Auto Researcher: Refresh Tracked Papers"
      },
      {
        "command": "tracker.savePaper",
        "title": "Auto Researcher: Save Tracked Paper"
      },
      {
        "command": "library.refresh",
        "title": "Auto Researcher: Refresh Library"
      },
      {
        "command": "library.markRead",
        "title": "Auto Researcher: Mark Paper Read"
      },
      {
        "command": "library.markUnread",
        "title": "Auto Researcher: Mark Paper Unread"
      },
      {
        "command": "library.openPdf",
        "title": "Auto Researcher: Open Paper PDF"
      },
      {
        "command": "library.queueReader",
        "title": "Auto Researcher: Queue Reader"
      },
      {
        "command": "aris.newRun",
        "title": "ARIS: New Run"
      },
      {
        "command": "aris.refresh",
        "title": "ARIS: Refresh"
      },
      {
        "command": "aris.retryRun",
        "title": "ARIS: Retry Run"
      },
      {
        "command": "aris.copyRunId",
        "title": "ARIS: Copy Run ID"
      }
    ],
    "configuration": {
      "title": "Auto Researcher",
      "properties": {
        "aris.apiBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:3000/api",
          "description": "Base URL for the Auto Researcher API."
        },
        "aris.refreshIntervalSeconds": {
          "type": "number",
          "default": 20,
          "minimum": 5,
          "description": "Refresh interval for the ARIS run list."
        },
        "aris.defaultProjectId": {
          "type": "string",
          "default": "default-project",
          "description": "Default ARIS project id for new runs."
        },
        "aris.defaultWorkflowType": {
          "type": "string",
          "default": "literature_review",
          "description": "Default ARIS workflow type for new runs."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "test": "npm run compile && node --test dist/test/suite/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.97.0",
    "typescript": "^5.8.2"
  }
}
